      <div id="cr_prev" style="margin-top:8px">${c.img?`<img src="${c.img}" style="max-height:120px;border-radius:8px;border:1px solid var(--line)">`:""}</div></div>
    <div class="frow"><label class="f">勝因メモ（何が効いたか）</label><textarea id="cr_memo">${esc(c.memo||"")}</textarea></div>`,`
