    <h2 class="ds">エリア別内訳</h2>
    <table class="dtable">
      <tr><th>エリア</th><th style="width:18%">配布部数</th><th style="width:18%">反響数</th><th style="width:18%">反響率</th></tr>
      ${areaRows.map(([a,v])=>`<tr><td>${esc(a)}</td><td class="num">${num(v.c)}</td><td class="num">${num(v.r)}</td><td class="num">${v.c?pct(Math.round(v.r/v.c*100*1000)/1000):"—"}</td></tr>`).join("")}
      <tr class="total"><td>合計</td><td class="num">${num(totC)}</td><td class="num">${num(totR)}</td><td class="num">${pct(Math.round(cvr*1000)/1000)}</td></tr>
