RENDER.responses=function(){
  setActions(`<button onclick="exportCSV('responses')">CSV出力</button>`);
  const rs=[...DB.responses].sort((a,b)=>b.date.localeCompare(a.date));
  const totC=rs.reduce((s,r)=>s+ +r.copies,0),totR=rs.reduce((s,r)=>s+ +r.responses,0);

  // エリア別集計
  const byArea={};rs.forEach(r=>{byArea[r.area]=byArea[r.area]||{c:0,r:0};byArea[r.area].c+= +r.copies;byArea[r.area].r+= +r.responses});
  const areaData=Object.entries(byArea).map(([a,v])=>({label:a,value:v.c?v.r/v.c*100:0,sub:`${num(v.c)}部 / ${num(v.r)}件 / ${v.c?pct(Math.round(v.r/v.c*100*1000)/1000):"—"}`}))
    .sort((a,b)=>b.value-a.value).slice(0,10);

  // 業種別集計
  const byInd={};rs.forEach(r=>{
    const d=deal(r.dealId);const cust=d?DB.customers.find(c=>c.id===d.customerId):null;
    const ind=cust?.industry||"その他";
    byInd[ind]=byInd[ind]||{c:0,r:0};byInd[ind].c+= +r.copies;byInd[ind].r+= +r.responses});
  const indData=Object.entries(byInd).map(([a,v])=>({label:a,value:v.c?v.r/v.c*100:0,sub:v.c?pct(Math.round(v.r/v.c*100*1000)/1000):"—"}))
    .sort((a,b)=>b.value-a.value);

  const activeDeals=DB.deals.filter(d=>["受注","配布中","報告・反響"].includes(d.stage));

  $("#view").innerHTML=`
  <div class="metrics" style="grid-template-columns:repeat(3,1fr)">
    <div class="metric"><small>累計配布部数</small><strong>${num(totC)}<em>部</em></strong><span>記録 ${rs.length}件</span></div>
    <div class="metric m2"><small>累計反響数</small><strong>${num(totR)}<em>件</em></strong><span>問い合わせ・来店・QR等</span></div>
    <div class="metric m4"><small>全体反響率</small><strong>${totC?pct(Math.round(totR/totC*100*1000)/1000):"—"}</strong><span>反響 ÷ 配布部数</span></div>
  </div>
  <div class="grid-31">
    <div class="stack">
      <section class="panel">
        <div class="panel-head"><div><p class="panel-title">エリア別 反響率ランキング</p><p class="panel-note">「どこに撒くと反響が出るか」を営業トークに使う。</p></div></div>
        <div class="panel-body">${hBars(areaData)}</div>
      </section>
      <section class="panel">
        <div class="panel-head"><div><p class="panel-title">業種別 反響率</p><p class="panel-note">自社実績。提案書の説得材料になる。</p></div></div>
        <div class="panel-body">${hBars(indData)}</div>
      </section>
      <section class="panel">
        <div class="panel-head"><div><p class="panel-title">記録一覧</p></div><span class="badge gray">${rs.length}件</span></div>
        <div class="panel-body">${rs.length?`<div style="overflow-x:auto"><table class="table">
          <thead><tr><th>配布日</th><th>案件</th><th>エリア</th><th class="num">配布</th><th class="num">反響</th><th class="num">率</th><th></th></tr></thead>
          <tbody>${rs.slice(0,50).map(r=>{const d=deal(r.dealId);return`<tr>
            <td>${fmtD(r.date)}</td><td style="font-weight:400">${d?esc(d.title):"—"}</td><td>${esc(r.area)}</td>
            <td class="num">${num(r.copies)}</td><td class="num">${num(r.responses)}</td>
            <td class="num">${r.copies?pct(Math.round(r.responses/r.copies*100*1000)/1000):"—"}</td>
            <td><button class="btn-sm ghost-danger" onclick="delResp('${r.id}')">削除</button></td></tr>`}).join("")}</tbody></table></div>`
        :`<div class="empty"><strong>実績がまだありません</strong>右のフォームから配布実績と反響数を記録してください。</div>`}</div>
      </section>
    </div>
    <section class="panel">
      <div class="panel-head"><div><p class="panel-title">実績を記録</p><p class="panel-note">案件×エリア×日付で記録します。</p></div></div>
      <div class="panel-body">
        ${activeDeals.length?`
        <div class="frow"><label class="f">案件 *</label><select id="rf_deal">
          ${activeDeals.map(d=>`<option value="${d.id}">${esc(cname(d.customerId))}：${esc(d.title)}</option>`).join("")}</select></div>
        <div class="frow c2">
          <div><label class="f">配布日</label><input id="rf_date" type="date" value="${today()}"></div>
          <div><label class="f">エリア</label><select id="rf_area">${WARDS.map(w=>`<option>${w}</option>`).join("")}</select></div>
        </div>
        <div class="frow c2">
          <div><label class="f">配布部数</label><input id="rf_copies" type="number" value="5000" step="500" min="0"></div>
          <div><label class="f">反響数</label><input id="rf_resp" type="number" value="0" min="0"></div>
        </div>
        <div class="frow"><label class="f">備考</label><input id="rf_memo" type="text" placeholder="例：QRコード計測 / 電話問い合わせ"></div>
        <button class="primary" style="width:100%" onclick="saveResp()">記録する</button>
        <p style="font-size:11.5px;color:var(--muted);margin:12px 0 0;line-height:1.7">記録が貯まると、案件詳細から<b>反響報告書PDF</b>を1クリックで出せます。</p>`
        :`<div class="empty"><strong>記録できる案件がありません</strong>ステージが「受注」「配布中」「報告・反響」の案件が対象です。</div>`}
      </div>
    </section>
  </div>`;
};
function saveResp(){
  const dealId=$("#rf_deal").value;
  const copies=+$("#rf_copies").value||0,responses=+$("#rf_resp").value||0;
  if(!copies)return toast("配布部数を入力してください");
  DB.responses.unshift({id:uid(),dealId,date:$("#rf_date").value||today(),area:$("#rf_area").value,copies,responses,memo:$("#rf_memo").value.trim()});
  const d=deal(dealId);logAct(`反響記録：${d.title}（${$("#rf_area").value} ${num(copies)}部/${num(responses)}件）`);
  save();RENDER.responses();toast("記録しました");
}
function delResp(id){DB.responses=DB.responses.filter(r=>r.id!==id);save();RENDER.responses();toast("削除しました")}

