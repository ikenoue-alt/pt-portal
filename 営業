    <div><small>配布コスト</small><b>${yen(cost)}</b></div>
    <div><small>予測反響</small><b>${(Math.round(leads*10)/10).toLocaleString()} 件</b></div>
    <div><small>予測成約 → 売上</small><b>${(Math.round(deals*10)/10).toLocaleString()}件 / ${yen(rev)}</b></div>
    <div><small>投資対効果</small><b style="color:${roi>=0?"var(--success)":"var(--danger)"}">${Math.round(roi)}%</b></div>
  </div>`;
}

