<!doctype html>
<html lang="ja">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>POSTECH Sales Cloud</title>
<style>
:root{
  --bg:#f4f6f8; --surface:#fff; --surface-2:#f9fafb;
  --ink:#151922; --muted:#667085; --line:#dfe4ea; --line-soft:#edf0f3;
  --nav:#172233; --nav-2:#202d41;
  --brand:#1f5b8f; --brand-dark:#173f66; --brand-soft:#e8f0f7;
  --accent:#b58b2b; --accent-soft:#fff8e4;
  --success:#25745a; --success-soft:#eaf7f1;
  --warn:#aa6a1f; --warn-soft:#fdf3e4;
  --danger:#9f3a38; --danger-soft:#fff0ef;
  --shadow:0 18px 45px rgba(16,24,40,.08);
  --radius:16px; --radius-sm:10px;
}
*{box-sizing:border-box}
html,body{height:100%}
body{margin:0;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","Hiragino Sans","Yu Gothic",Meiryo,sans-serif;background:var(--bg);color:var(--ink);letter-spacing:.01em;font-size:14px}
.app{min-height:100vh;display:grid;grid-template-columns:250px 1fr}

/* ===== sidebar ===== */
aside{background:linear-gradient(180deg,var(--nav),var(--nav-2));color:#fff;padding:22px 14px;position:sticky;top:0;height:100vh;overflow-y:auto;z-index:30}
.logo{display:flex;align-items:center;gap:11px;margin-bottom:22px;padding:0 8px;cursor:pointer}
.mark{width:38px;height:38px;border-radius:12px;background:#fff;display:grid;place-items:center;color:var(--brand-dark);font-weight:900;letter-spacing:-.04em;font-size:17px;flex:none}
.logo strong{display:block;font-size:14px;line-height:1.15}
.logo span{display:block;color:#b9c5d6;font-size:10.5px;margin-top:4px}
.navgroup{font-size:10px;font-weight:800;color:#7f8ca0;letter-spacing:.12em;padding:14px 10px 6px}
nav{display:grid;gap:4px}
.navitem{display:flex;align-items:center;gap:11px;padding:10px 10px;border-radius:11px;color:#c8d2df;font-size:13px;text-decoration:none;cursor:pointer;border:0;background:none;text-align:left;font-family:inherit;width:100%}
.navitem:hover{background:rgba(255,255,255,.07);color:#fff}
.navitem.active{background:rgba(255,255,255,.12);color:#fff}
.navitem svg{width:17px;height:17px;flex:none;opacity:.85}
.navitem.active svg{color:var(--accent);opacity:1}
.navitem .cnt{margin-left:auto;font-size:10.5px;font-weight:800;background:rgba(255,255,255,.12);border-radius:999px;padding:2px 8px;color:#dbe4ee}
.sidebox{margin-top:20px;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.06);border-radius:14px;padding:13px}
.sidebox p{margin:0;color:#d5deea;font-size:11.5px;line-height:1.7}
.sidebox a{color:#9fc4e8;font-weight:700;text-decoration:none}

/* ===== main frame ===== */
main{padding:24px 32px 60px;min-width:0}
.topbar{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:22px;gap:16px;flex-wrap:wrap}
.breadcrumb{font-size:12px;color:var(--muted);margin-bottom:7px}
h1{font-size:24px;margin:0;letter-spacing:-.03em}
.lead{margin:7px 0 0;color:var(--muted);font-size:13px}
.actions{display:flex;gap:9px;align-items:center;flex-wrap:wrap}
button,.btn{border:1px solid var(--line);background:#fff;color:var(--ink);padding:9px 15px;border-radius:999px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;box-shadow:0 1px 1px rgba(16,24,40,.03);white-space:nowrap}
button:hover,.btn:hover{border-color:#c3ccd6}
.primary{background:var(--brand);border-color:var(--brand);color:#fff}
.primary:hover{background:var(--brand-dark);border-color:var(--brand-dark)}
.ghost-danger{color:var(--danger);border-color:#e7c6c5}
.btn-sm{padding:6px 11px;font-size:12px}
.btn-icon{padding:7px 9px;line-height:0}
button:disabled{opacity:.45;cursor:default}

/* ===== panels ===== */
.panel{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow)}
.panel-head{padding:16px 20px;border-bottom:1px solid var(--line-soft);display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap}
.panel-title{font-size:15px;font-weight:800;margin:0}
.panel-note{font-size:12px;color:var(--muted);margin:3px 0 0}
.panel-body{padding:18px 20px}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:18px;align-items:start}
.grid-31{display:grid;grid-template-columns:minmax(0,1fr) 340px;gap:20px;align-items:start}
.stack{display:grid;gap:16px}

/* ===== metrics ===== */
.metrics{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:13px;margin-bottom:20px}
.metric{background:#fff;border:1px solid var(--line);border-radius:15px;padding:15px 16px;min-height:104px;position:relative;overflow:hidden;cursor:pointer}
.metric:before{content:"";position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--brand)}
.metric.m2:before{background:var(--success)}
.metric.m3:before{background:var(--warn)}
.metric.m4:before{background:var(--accent)}
.metric small{display:block;color:var(--muted);font-size:12px;margin-bottom:9px}
.metric strong{display:block;font-size:27px;letter-spacing:-.04em}
.metric strong em{font-style:normal;font-size:14px;color:var(--muted);font-weight:700;margin-left:3px}
.metric span{display:block;color:var(--muted);font-size:11.5px;margin-top:7px}

/* ===== badges ===== */
.badge{font-size:11px;font-weight:800;border:1px solid var(--line);border-radius:999px;padding:4px 10px;background:#fff;white-space:nowrap;color:var(--brand-dark);display:inline-block}
.badge.gold{color:#6e5215;background:var(--accent-soft);border-color:#ead28b}
.badge.green{color:#1e6a52;background:var(--success-soft);border-color:#b9dfcf}
.badge.red{color:#873230;background:var(--danger-soft);border-color:#e7b9b7}
.badge.orange{color:#8a5a1a;background:var(--warn-soft);border-color:#ecd2a8}
.badge.blue{color:#1f5b8f;background:var(--brand-soft);border-color:#bcd3e6}
.badge.gray{color:#5b6674;background:#f1f3f6;border-color:#dde2e9}

/* ===== tables ===== */
.table{width:100%;border-collapse:separate;border-spacing:0 7px}
.table th{text-align:left;font-size:11px;color:var(--muted);font-weight:800;padding:0 12px 3px;white-space:nowrap}
.table td{background:var(--surface-2);border-top:1px solid var(--line-soft);border-bottom:1px solid var(--line-soft);padding:11px 12px;font-size:13px;vertical-align:middle}
.table td:first-child{border-left:1px solid var(--line-soft);border-radius:12px 0 0 12px;font-weight:800}
.table td:last-child{border-right:1px solid var(--line-soft);border-radius:0 12px 12px 0}
.table tr.clickable{cursor:pointer}
.table tr.clickable:hover td{background:#f1f5f9}
.table .num{text-align:right;font-variant-numeric:tabular-nums}
.table th.num{text-align:right}
.empty{border:1px dashed #cfd6df;border-radius:16px;background:#fbfcfd;padding:32px;text-align:center;color:var(--muted);font-size:13px}
.empty strong{display:block;color:var(--ink);font-size:15px;margin-bottom:7px}

/* ===== forms ===== */
label.f{display:block;font-size:11.5px;font-weight:800;color:var(--muted);margin-bottom:5px}
input[type=text],input[type=number],input[type=date],input[type=tel],input[type=email],select,textarea{
  width:100%;border:1px solid var(--line);border-radius:10px;padding:9px 11px;font-size:13px;font-family:inherit;background:#fff;color:var(--ink)}
input:focus,select:focus,textarea:focus{outline:2px solid rgba(31,91,143,.25);border-color:var(--brand)}
textarea{resize:vertical;min-height:70px}
.frow{display:grid;gap:12px;margin-bottom:12px}
.frow.c2{grid-template-columns:1fr 1fr}
.frow.c3{grid-template-columns:1fr 1fr 1fr}
.frow.c4{grid-template-columns:repeat(4,1fr)}
.searchbar{display:flex;gap:9px;flex-wrap:wrap;align-items:center}
.searchbar input,.searchbar select{width:auto;min-width:150px}
.chips{display:flex;flex-wrap:wrap;gap:6px}
.chip{border:1px solid var(--line);border-radius:999px;padding:5px 11px;font-size:12px;font-weight:700;cursor:pointer;background:#fff;color:var(--muted);user-select:none}
.chip.on{background:var(--brand);border-color:var(--brand);color:#fff}

/* ===== kanban ===== */
.kanban{display:grid;grid-template-columns:repeat(6,minmax(190px,1fr));gap:12px;overflow-x:auto;align-items:start;padding-bottom:6px}
.kcol{background:var(--surface-2);border:1px solid var(--line-soft);border-radius:14px;min-height:120px}
.kcol-h{padding:11px 13px;font-size:12px;font-weight:800;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--line-soft)}
.kcol-h .cnt{font-size:11px;color:var(--muted);font-weight:800}
.kcol-b{padding:9px;display:grid;gap:8px;min-height:60px}
.kcard{background:#fff;border:1px solid var(--line);border-radius:12px;padding:11px 12px;cursor:grab;box-shadow:0 1px 2px rgba(16,24,40,.05)}
.kcard:active{cursor:grabbing}
.kcard h4{margin:0 0 5px;font-size:13px}
.kcard p{margin:0;font-size:11.5px;color:var(--muted);line-height:1.55}
.kcard .kfoot{display:flex;justify-content:space-between;align-items:center;margin-top:8px;gap:6px}
.kcard .kfoot b{font-size:12px;color:var(--brand-dark);font-variant-numeric:tabular-nums}
.kcol.dragover{outline:2px dashed var(--brand);outline-offset:-4px}

/* ===== cards grid (creatives) ===== */
.cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(215px,1fr));gap:14px}
.ccard{background:#fff;border:1px solid var(--line);border-radius:15px;overflow:hidden;cursor:pointer}
.ccard:hover{border-color:#c3ccd6}
.cthumb{height:135px;background:#eef2f6;display:grid;place-items:center;color:#9aa7b6;font-size:11px;font-weight:800;border-bottom:1px solid var(--line-soft);overflow:hidden}
.cthumb img{width:100%;height:100%;object-fit:cover}
.cbody{padding:12px 13px}
.cbody h4{margin:0 0 5px;font-size:13.5px}
.cbody p{margin:0 0 8px;font-size:11.5px;color:var(--muted)}
.cvr-line{display:flex;justify-content:space-between;font-size:11.5px;color:var(--muted)}
.cvr-line b{color:var(--success);font-size:13px}

/* ===== charts ===== */
.chartbox{border:1px solid var(--line);border-radius:16px;background:linear-gradient(180deg,#fff,#f9fafb);padding:14px;overflow:hidden}
.chartbox h4{margin:2px 4px 10px;font-size:13px}
.legend{display:flex;gap:14px;flex-wrap:wrap;font-size:11.5px;color:var(--muted);margin:8px 4px 0}
.legend i{display:inline-block;width:10px;height:10px;border-radius:3px;margin-right:5px;vertical-align:-1px}

/* ===== modal ===== */
.overlay{position:fixed;inset:0;background:rgba(15,22,33,.45);display:none;place-items:center;z-index:100;padding:20px}
.overlay.show{display:grid}
.modal{background:#fff;border-radius:18px;width:min(720px,100%);max-height:90vh;overflow:auto;box-shadow:0 30px 80px rgba(0,0,0,.3)}
.modal.wide{width:min(980px,100%)}
.modal-h{padding:18px 22px;border-bottom:1px solid var(--line-soft);display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:#fff;z-index:2;border-radius:18px 18px 0 0}
.modal-h h2{margin:0;font-size:17px}
.modal-b{padding:20px 22px}
.modal-f{padding:14px 22px 18px;border-top:1px solid var(--line-soft);display:flex;justify-content:space-between;gap:10px;position:sticky;bottom:0;background:#fff;border-radius:0 0 18px 18px}
.modal-f .right{display:flex;gap:9px;margin-left:auto}
.x{border:0;background:none;font-size:20px;cursor:pointer;color:var(--muted);padding:4px 8px;box-shadow:none}

/* ===== toast ===== */
#toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#172233;color:#fff;padding:11px 20px;border-radius:999px;font-size:13px;font-weight:700;opacity:0;pointer-events:none;transition:.25s;z-index:200;box-shadow:0 10px 30px rgba(0,0,0,.3)}
#toast.show{opacity:1}

/* ===== detail fields ===== */
.dfield{display:grid;grid-template-columns:120px 1fr;border-bottom:1px solid var(--line-soft);padding:9px 0;font-size:13px;gap:8px}
.dfield b{color:var(--muted);font-weight:800;font-size:12px}
.timeline{display:grid;gap:11px}
.timeitem{display:grid;grid-template-columns:78px 1fr;gap:10px;font-size:12px}
.timeitem b{color:var(--brand-dark);font-variant-numeric:tabular-nums}
.timeitem span{color:var(--muted);line-height:1.55}

/* ===== navi (sales knowledge) ===== */
.navi-sec{margin-bottom:8px}
.acc{border:1px solid var(--line);border-radius:14px;background:#fff;margin-bottom:10px;overflow:hidden}
.acc summary{padding:14px 18px;font-weight:800;font-size:13.5px;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center}
.acc summary::-webkit-details-marker{display:none}
.acc summary:after{content:"＋";color:var(--muted);font-weight:400}
.acc[open] summary:after{content:"－"}
.acc .acc-b{padding:0 18px 16px;font-size:13px;line-height:1.85;color:#333c49}
.acc .acc-b h5{margin:14px 0 6px;font-size:12.5px;color:var(--brand-dark)}
.talk{border-left:3px solid var(--brand);background:var(--brand-soft);border-radius:0 10px 10px 0;padding:10px 14px;margin:8px 0;font-size:12.5px;line-height:1.8}
.talk.obj{border-color:var(--warn);background:var(--warn-soft)}
.kv{width:100%;border-collapse:collapse;font-size:12.5px;margin:6px 0}
.kv th,.kv td{border:1px solid var(--line-soft);padding:7px 10px;text-align:left}
.kv th{background:var(--surface-2);font-size:11px;color:var(--muted)}
.kv td.num{text-align:right;font-variant-numeric:tabular-nums}

/* ===== print document ===== */
#printRoot{display:none}
.doc{width:210mm;min-height:296mm;background:#fff;margin:0 auto 14px;padding:18mm 17mm;position:relative;box-shadow:0 8px 30px rgba(0,0,0,.14);page-break-after:always}
.doc:last-child{page-break-after:auto}
.doc .side{position:absolute;left:0;top:0;bottom:0;width:5mm;background:linear-gradient(180deg,#1f5b8f,#b58b2b)}
.doc-eyebrow{font-size:10px;letter-spacing:.22em;color:var(--accent);font-weight:800;margin-bottom:6mm}
.doc h1.dt{font-size:29px;letter-spacing:-.02em;margin:0 0 4mm;line-height:1.35}
.doc h2.ds{font-size:16px;border-left:4px solid var(--brand);padding-left:10px;margin:10mm 0 5mm}
.doc p.dl{font-size:12px;color:#444;line-height:1.9;margin:0}
.doc-meta{margin-top:12mm;font-size:12px;color:#555;line-height:2}
.doc-foot{position:absolute;bottom:12mm;left:22mm;right:17mm;display:flex;justify-content:space-between;font-size:10px;color:#98a2b0}
.dtable{width:100%;border-collapse:collapse;font-size:12px}
.dtable th{background:#eef3f8;border:1px solid #d7dfe8;padding:8px 10px;text-align:left;font-size:11px;color:#33495e}
.dtable td{border:1px solid #d7dfe8;padding:8px 10px}
.dtable td.num{text-align:right;font-variant-numeric:tabular-nums}
.dtable tr.total td{background:#f7f1e5;font-weight:800}
.doc-hero{background:#f2f6fa;border:1px solid #d7e2ec;border-radius:10px;padding:14px 16px;display:grid;grid-template-columns:repeat(3,1fr);gap:12px;text-align:center}
.doc-hero small{display:block;font-size:10px;color:#5c6b7c;margin-bottom:4px;font-weight:800}
.doc-hero b{font-size:19px;letter-spacing:-.02em}
.doc-note{font-size:10.5px;color:#777;margin-top:3mm;line-height:1.7}

#printOverlay{position:fixed;inset:0;background:#525659;z-index:150;display:none;overflow:auto;padding:30px 16px 70px}
#printOverlay.show{display:block}
.print-tools{position:fixed;top:0;left:0;right:0;background:#172233;color:#fff;display:flex;justify-content:space-between;align-items:center;padding:10px 22px;z-index:160}
.print-tools b{font-size:13px}
.print-tools .actions button{box-shadow:none}
#printOverlay .doc-wrap{margin-top:46px}

@media print{
  body>*{display:none !important}
  #printOverlay{display:block !important;position:static;background:#fff;padding:0}
  #printOverlay .print-tools{display:none !important}
  #printOverlay .doc-wrap{display:block !important;margin:0}
  .doc{box-shadow:none;margin:0;width:auto;min-height:auto}
  @page{size:A4;margin:0}
}

/* ===== responsive ===== */
#menuBtn{display:none}
@media (max-width:1100px){
  .app{grid-template-columns:1fr}
  aside{position:fixed;left:-270px;width:260px;transition:left .25s;box-shadow:0 0 60px rgba(0,0,0,.35)}
  aside.open{left:0}
  #menuBtn{display:inline-block}
  main{padding:18px}
  .grid-31,.grid-2{grid-template-columns:1fr}
  .metrics{grid-template-columns:repeat(2,1fr)}
  .kanban{grid-template-columns:repeat(6,230px)}
}
@media (max-width:640px){
  .metrics{grid-template-columns:1fr 1fr}
  .frow.c2,.frow.c3,.frow.c4{grid-template-columns:1fr}
  .topbar{flex-direction:column}
}


/* =====================================================
   POSTECH Operations Console redesign
   - UI/UX appearance only. Business content, functions and data model preserved.
   ===================================================== */
:root{
  --bg:#f5f6f8;
  --surface:#ffffff;
  --surface-2:#fafafa;
  --ink:#111827;
  --muted:#6b7280;
  --line:#e5e7eb;
  --line-soft:#eef0f3;
  --line-strong:#cbd5e1;
  --nav:#101828;
  --nav-2:#101828;
  --brand:#1e3a5f;
  --brand-dark:#172e4a;
  --brand-soft:#eef4fa;
  --accent:#9a7a2f;
  --accent-soft:#fbf7ea;
  --success:#256d4f;
  --success-soft:#eef8f3;
  --warn:#a16207;
  --warn-soft:#fff7ed;
  --danger:#b42318;
  --danger-soft:#fff1f0;
  --shadow:none;
  --radius:8px;
  --radius-sm:6px;
}
html,body{background:var(--bg);font-size:14px;letter-spacing:0;color:var(--ink);}
body:before{content:"";position:fixed;inset:0 0 auto 0;height:3px;background:var(--brand);z-index:999;}
.app{grid-template-columns:248px 1fr;}
aside{background:#101828;border-right:1px solid #1f2937;padding:18px 12px;box-shadow:none;}
.logo{gap:10px;margin-bottom:14px;padding:0 6px 16px;border-bottom:1px solid rgba(255,255,255,.08);}
.mark{width:34px;height:34px;border-radius:6px;color:#101828;font-size:15px;background:#fff;}
.logo strong{font-size:13px;letter-spacing:.01em;}
.logo span{font-size:10px;color:#98a2b3;}
.navgroup{font-size:10px;color:#858d9b;letter-spacing:.14em;padding:13px 8px 5px;}
nav{gap:2px;}
.navitem{border-radius:6px;padding:9px 10px;color:#cbd5e1;font-weight:600;border-left:3px solid transparent;}
.navitem:hover{background:#182230;color:#fff;}
.navitem.active{background:#1d2939;color:#fff;border-left-color:var(--accent);}
.navitem svg{width:16px;height:16px;opacity:.75;}
.navitem.active svg{color:#fff;opacity:.92;}
.navitem .cnt{background:#344054;color:#fff;border-radius:4px;padding:1px 6px;font-size:10px;}
.sidebox{border:1px solid rgba(255,255,255,.08);background:#0b1220;border-radius:8px;margin-top:18px;padding:12px;}
.sidebox p{display:flex;align-items:center;justify-content:space-between;gap:10px;margin:0 0 8px;color:#d0d5dd;font-size:11px;line-height:1.45;}
.sidebox p:last-child{margin-bottom:0;}
.sidebox b{color:#98a2b3;font-size:10px;letter-spacing:.08em;}
.sidebox a{color:#d7e7f7;text-decoration:none;border-bottom:1px solid rgba(215,231,247,.35);}
main{padding:22px 28px 56px;background:linear-gradient(180deg,#f7f8fa 0,#f5f6f8 180px);}
.topbar{align-items:center;border-bottom:1px solid var(--line);padding-bottom:16px;margin-bottom:18px;}
.breadcrumb{font-size:11px;margin-bottom:6px;color:#7b8494;}
h1{font-size:22px;letter-spacing:-.02em;font-weight:800;}
.lead{font-size:12.5px;color:#667085;margin-top:5px;}
.actions{gap:8px;}
button,.btn{border-radius:6px;box-shadow:none;padding:8px 13px;font-weight:650;background:#fff;border-color:#d0d5dd;color:#1f2937;}
button:hover,.btn:hover{border-color:#98a2b3;background:#f9fafb;}
.primary{background:var(--brand);border-color:var(--brand);color:#fff;}
.primary:hover{background:var(--brand-dark);border-color:var(--brand-dark);}
.ghost-danger{color:var(--danger);border-color:#f0c7c3;background:#fff;}
.btn-sm{padding:6px 10px;border-radius:6px;}
.panel{border:1px solid var(--line);border-radius:8px;box-shadow:none;background:#fff;}
.panel-head{padding:14px 16px;border-bottom:1px solid var(--line);background:#fff;border-radius:8px 8px 0 0;}
.panel-title{font-size:14px;font-weight:800;}
.panel-note{font-size:11.5px;margin-top:2px;}
.panel-body{padding:16px;}
.stack{gap:14px;}
.grid-2{gap:16px;}
