/* ---------- CSV / JSON ---------- */
function dl(name,content,type){
  const b=new Blob([content],{type});const a=document.createElement("a");
  a.href=URL.createObjectURL(b);a.download=name;a.click();URL.revokeObjectURL(a.href);
}
function csvEsc(v){v=String(v??"");return /[",\n]/.test(v)?'"'+v.replace(/"/g,'""')+'"':v}
function exportCSV(kind){
  let rows=[];
  if(kind==="customers"){
    rows=[["社名","業種","ステータス","担当者","電話","エリア","メモ","登録日"]];
    DB.customers.forEach(c=>rows.push([c.name,c.industry,c.status,c.contact,c.tel,(c.areas||[]).join("・"),c.memo,c.createdAt]));
  }else if(kind==="deals"){
    rows=[["案件名","顧客","ステージ","部数","サイズ","方法","金額","開始","終了","エリア","次回日","次回内容","メモ"]];
    DB.deals.forEach(d=>rows.push([d.title,cname(d.customerId),d.stage,d.copies,d.size,d.method,d.price,d.startDate,d.endDate,(d.areas||[]).join("・"),d.nextDate,d.nextAction,d.memo]));
  }else{
    rows=[["配布日","案件","顧客","エリア","配布部数","反響数","反響率(%)","備考"]];
    DB.responses.forEach(r=>{const d=deal(r.dealId);rows.push([r.date,d?d.title:"",d?cname(d.customerId):"",r.area,r.copies,r.responses,r.copies?Math.round(r.responses/r.copies*100*1000)/1000:"",r.memo])});
  }
  const csv="\uFEFF"+rows.map(r=>r.map(csvEsc).join(",")).join("\r\n");
  dl(`psc_${kind}_${today()}.csv`,csv,"text/csv");toast("CSVを書き出しました");
}
function backupJSON(){dl(`psc_backup_${today()}.json`,JSON.stringify(DB,null,1),"application/json");toast("バックアップを書き出しました")}
function restoreJSON(input){
  const f=input.files[0];if(!f)return;
  const rd=new FileReader();
  rd.onload=()=>{try{
    const d=JSON.parse(rd.result);
    if(!d.customers||!d.deals)throw 0;
    DB=Object.assign(blank(),d);save();go("dashboard");toast("復元しました");
  }catch(e){toast("復元に失敗しました（形式が違います）")}};
  rd.readAsText(f);
}
function wipeAll(){
  if(!confirm("全データを削除します。よろしいですか？"))return;
  if(!confirm("本当に削除しますか？この操作は取り消せません。"))return;
  DB=blank();save();go("dashboard");toast("全データを削除しました");
}

