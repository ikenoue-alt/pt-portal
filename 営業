function barChart(data,opts={}){
  // data:[{label,v1,v2?}]  v1棒 v2折れ線(任意)
  const W=opts.w||620,H=opts.h||230,pad={t:16,r:18,b:30,l:46};
  const iw=W-pad.l-pad.r,ih=H-pad.t-pad.b;
  const max=Math.max(1,...data.map(d=>d.v1));
  const max2=Math.max(0.0001,...data.map(d=>d.v2||0));
  const bw=Math.min(46,iw/data.length*0.56);
  let g="";
  for(let i=0;i<4;i++){const y=pad.t+ih*i/3;g+=`<line x1="${pad.l}" y1="${y}" x2="${W-pad.r}" y2="${y}" stroke="#edf0f3"/>`;
    g+=`<text x="${pad.l-7}" y="${y+4}" font-size="10" fill="#98a2b0" text-anchor="end">${num(Math.round(max*(3-i)/3))}</text>`}
  let line="",dots="";
  data.forEach((d,i)=>{
    const cx=pad.l+iw*(i+0.5)/data.length;
    const bh=ih*d.v1/max;
    g+=`<rect x="${cx-bw/2}" y="${pad.t+ih-bh}" width="${bw}" height="${Math.max(bh,1)}" rx="6" fill="#9fc0da" stroke="#7ea6c6"/>`;
    g+=`<text x="${cx}" y="${H-9}" font-size="10.5" fill="#667085" text-anchor="middle">${esc(d.label)}</text>`;
    if(d.v2!==undefined){
      const cy=pad.t+ih-ih*(d.v2/max2);
      line+=(line?" L":"M")+cx+" "+cy;
      dots+=`<circle cx="${cx}" cy="${cy}" r="4" fill="#b58b2b" stroke="#fff" stroke-width="1.5"/>`;
      dots+=`<text x="${cx}" y="${cy-9}" font-size="10" fill="#8a6a1d" text-anchor="middle" font-weight="700">${d.v2}</text>`;
    }
  });
  if(line)g+=`<path d="${line}" fill="none" stroke="#b58b2b" stroke-width="2"/>`+dots;
  return `<svg viewBox="0 0 ${W} ${H}" style="width:100%;height:auto;display:block">${g}</svg>`;
}
function hBars(data,opts={}){
