  goodDeals.slice(0,3).forEach(d=>{
    todos.push({t:`${cname(d.customerId)}：再提案チャンス`,p:"反響率が基準超え。実績を武器に次回配布を提案。",b:`<span class="badge green">好機</span>`,fn:`openDealDetail('${d.id}')`});
  });

  const funnel=STAGES.map(s=>({label:s,value:DB.deals.filter(d=>d.stage===s).length,sub:DB.deals.filter(d=>d.stage===s).length+"件"}));

  const actionRows=todos.length?todos.map(t=>`
